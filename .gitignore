# Dados (grandes demais, ou sensíveis) — mas mantém a estrutura de
# pastas e os arquivos pequenos/reproduzíveis já filtrados para os
# 28 países (não os dumps brutos completos da UN WPP, que têm ~200MB
# e cobrem todos os ~200 países do mundo — ver src/data_pipeline.py).
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/raw/un_wpp.csv
!data/processed/n_index_2024.csv

