# ═══════════════════════════════════════════════════════════════════════════
# AINU.SYSTEMS v3.1.0 - Arquivo de Exemplo de Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores necessários

# ─────────────────────────────────────────────────────────────────────────
# BANCO DE DADOS
# ─────────────────────────────────────────────────────────────────────────
# PostgreSQL Local (para desenvolvimento)
# DATABASE_URL=postgresql://ainu:ainu123@localhost:5432/ainu_narayama

# PostgreSQL Docker (para docker-compose)
DATABASE_URL=postgresql://ainu:ainu123@postgres:5432/ainu_narayama

# SQLite (para testes simples - NÃO RECOMENDADO para produção)
# DATABASE_URL=sqlite:///./test.db

# ─────────────────────────────────────────────────────────────────────────
# JWT - AUTENTICAÇÃO
# ─────────────────────────────────────────────────────────────────────────
# IMPORTANTE: Gere uma chave secreta forte (mínimo 32 caracteres)
# No terminal: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=ainu-secret-key-very-secure-minimum-32-characters-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# ─────────────────────────────────────────────────────────────────────────
# CORS - ORIGENS PERMITIDAS
# ─────────────────────────────────────────────────────────────────────────
# Separadas por vírgula, SEM ESPAÇOS
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000,https://narayama.live

# ─────────────────────────────────────────────────────────────────────────
# URLs DE SERVIÇOS
# ─────────────────────────────────────────────────────────────────────────
# Local
# BACKEND_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:8501

# Docker
BACKEND_URL=http://backend:8000
FRONTEND_URL=http://localhost:8501

# Produção (Railway)
# BACKEND_URL=https://seu-backend-url.railway.app
# FRONTEND_URL=https://seu-frontend-url.app

# ─────────────────────────────────────────────────────────────────────────
# EMAIL - NOTIFICAÇÕES
# ─────────────────────────────────────────────────────────────────────────
# Use Gmail com uma Senha de App (não a senha da conta)
# Veja: https://support.google.com/accounts/answer/185833
EMAIL_ADMIN=narayama.live@gmail.com
EMAIL_PASSWORD=seu-app-password-aqui

# ─────────────────────────────────────────────────────────────────────────
# AGENTE COLETOR
# ─────────────────────────────────────────────────────────────────────────
# Ativar/desativar agente automático
AGENTE_ATIVO=true

# Timezone (IANA format)
AGENTE_TIMEZONE=America/Sao_Paulo

# Agendamento: qual dia da semana (0=seg, 1=ter, ..., 4=sex)
AGENTE_DIA=friday

# Hora (0-23)
AGENTE_HORA=14

# Minuto (0-59)
AGENTE_MINUTO=0

# ═══════════════════════════════════════════════════════════════════════════
# EXEMPLOS DE CONFIGURAÇÃO
# ═══════════════════════════════════════════════════════════════════════════

# ─── Desenvolvimento Local ───
# DATABASE_URL=sqlite:///./test.db
# BACKEND_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:8501
# AGENTE_ATIVO=false

# ─── Docker Local ───
# DATABASE_URL=postgresql://ainu:ainu123@postgres:5432/ainu_narayama
# BACKEND_URL=http://backend:8000
# FRONTEND_URL=http://localhost:8501
# AGENTE_ATIVO=true

# ─── Railway Produção ───
# DATABASE_URL=postgresql://user:pass@db.railway.internal/ainu
# BACKEND_URL=https://seu-backend.railway.app
# FRONTEND_URL=https://seu-frontend.railway.app
# AGENTE_ATIVO=true

# ═══════════════════════════════════════════════════════════════════════════
# NOTAS
# ═══════════════════════════════════════════════════════════════════════════
# 1. Nunca commite .env em Git (use .gitignore)
# 2. Valores sensíveis devem estar em .env, não em código
# 3. Para Railway, use as variáveis do painel de deployment
# 4. Gere SECRET_KEY novo para cada ambiente
# 5. Use senhas de app do Gmail, não senha da conta
# ═══════════════════════════════════════════════════════════════════════════
