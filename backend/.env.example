# ================================================================
# AINU-Narayama Backend - Configuração
# ================================================================

# Ambiente
ENVIRONMENT=development  # ou: production

# Banco de Dados
DATABASE_URL=postgresql://ainu_user:ainu_password@localhost:5432/ainu_db

# JWT Secret (gere com: openssl rand -hex 32)
SECRET_KEY=seu-secret-key-super-seguro-aqui-mude-em-producao

# Admin Email
ADMIN_EMAIL=narayama.live@gmail.com

# ================================================================
# SCHEDULER (Agente Coletor)
# ================================================================

# Timezone para execução agendada
SCHEDULER_TIMEZONE=America/Sao_Paulo
# Alternativa para Nagano: Asia/Tokyo

# ================================================================
# EMAIL SMTP (Notificações)
# ================================================================

# Usando Gmail (requer App Password com 2FA)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-app-password-16-caracteres

# ================================================================
# CORS e Segurança
# ================================================================

# URLs permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://narayama.live

# ================================================================
# LOGS
# ================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/ainu.log

# ================================================================
# DESENVOLVIMENTO
# ================================================================

# Debug mode
DEBUG=False
